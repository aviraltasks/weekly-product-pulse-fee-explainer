# Copy to .env and adjust (never commit .env)

# Allowed browser origin for the Next.js app (dev default: localhost:3000)
FRONTEND_ORIGIN=http://localhost:3000

# --- Phase 2: Play Store reviews → CSV (no API keys required) ---
# Optional: override data directory (default: apps/backend/data/)
# REVIEWS_DATA_DIR=
# Free-tier note:
# STORAGE_MODE=ephemeral   # default; local files may reset after restart/redeploy
# STORAGE_MODE=persistent  # set when durable disk is guaranteed

# Listing: https://play.google.com/store/apps/details?id=in.indwealth&hl=en_IN
PLAY_STORE_APP_ID=in.indwealth

# Scraper locale (country may be en_IN style in URL; code uses lang + country below)
PLAY_STORE_LANG=en
PLAY_STORE_COUNTRY=in

# Max reviews to pull per run (paginated; capped for safety)
PLAY_FETCH_MAX_REVIEWS=500

# Drop very short reviews (noise)
REVIEW_MIN_CONTENT_LENGTH=10
# Minimum alpha word tokens in a review to count as meaningful.
REVIEW_MIN_MEANINGFUL_WORDS=3
# New meaningful reviews needed before auto-trigger is considered "run_ready".
MIN_MEANINGFUL_NEW_REVIEWS_FOR_PULSE=5

# Background job: fetch reviews into reviews_master.csv only (no Doc / email)
SCHEDULER_ENABLED=true
FETCH_INTERVAL_HOURS=48
# Secure external trigger token for POST /api/reviews/fetch (GitHub Actions cron).
# CRON_TRIGGER_TOKEN=

# Set false in tests; optional: disable on constrained hosts
# SCHEDULER_ENABLED=false

# --- Phase 3: dual LLM pulse (Groq + Gemini) ---
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_API_KEY=
# Exact id from https://ai.google.dev/gemini-api/docs/models (must match API; no typos like …-preview-preview)
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
# PULSE_SAMPLE_MAX_REVIEWS=180
# PULSE_TRUNCATE_CHARS=380
# LLM_MAX_RETRIES=3
# LLM_RETRY_BACKOFF_SEC=1.2

# --- Phase 4: fee explainer (exit load) — two source URLs (no API keys) ---
# Defaults are baked in (INDmoney SBI Large Cap + SEBI investor). Set to empty string to disable fee block.
# FEE_SOURCE_URL_1=https://www.indmoney.com/mutual-funds/sbi-large-cap-fund-direct-growth-3046
# FEE_SOURCE_URL_2=https://investor.sebi.gov.in/exit_load.html
# Optional: override scenario title (defaults from data/fee_defaults.json)
# FEE_SCENARIO_TITLE=
# Optional: cache file path (default: apps/backend/data/fee_explainer_cache.json)
# FEE_CACHE_PATH=

# --- Phase 5: preview package (Weekly Pulse N, As on, doc + email JSON) ---
# PREVIEW_DISPLAY_TIMEZONE=Asia/Kolkata
# WEEKLY_PULSE_COUNTER_PATH=

# --- Phase 6: Google Doc append (service account; never commit the JSON key file) ---
# Create a Google Cloud service account with Google Docs API enabled; download JSON key; share your target Doc with the SA email (Editor).
# GOOGLE_DOC_ID=<id from docs.google.com/document/d/<id>/edit>
# GOOGLE_SERVICE_ACCOUNT_FILE=C:/path/to/service-account.json
# Preferred on hosted free tiers: paste compact JSON (single-line) into env.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Phase 7: subscribers + Gmail SMTP (App Password — never commit passwords) ---
# https://myaccount.google.com/apppasswords — use the 16-char password without spaces.
# GMAIL_SMTP_USER=your.address@gmail.com
# GMAIL_APP_PASSWORD=
# If true (default), /integrations/gmail/send only sends to emails in the subscribers store.
# GMAIL_STRICT_RECIPIENTS=true
# SUBSCRIBERS_STORE_PATH=
