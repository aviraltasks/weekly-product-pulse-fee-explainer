# Copy to .env.local for local overrides (optional in Phase 1)
# Public URL of the FastAPI backend (browser calls this from the admin UI later)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional server-only override used by Next route handlers/proxies.
# BACKEND_API_URL=http://localhost:8000
# Server-only secret used by /api/reviews/fetch proxy to call protected backend fetch endpoint.
# Must match backend CRON_TRIGGER_TOKEN.
# CRON_TRIGGER_TOKEN=
